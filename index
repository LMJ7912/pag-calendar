<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>PAG Calendar</title>
  <link rel="stylesheet" href="pag-calendar.min.css">
  <link rel="stylesheet" href="calendar-theme.css"> <!-- Optional theme -->
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 20px;
    }
  </style>
</head>
<body>

  <div id="calendar"></div>

  <script src="jquery.min.js"></script>
  <script src="moment.min.js"></script>
  <script src="evo-calendar.min.js"></script>
  <script>
    $(document).ready(function () {
      $('#calendar').evoCalendar({
        theme: "Midnight Blue", // Optional
        calendarEvents: [
          {
            id: 'event1',
            name: "Project Launch",
            date: "2025-07-20",
            type: "event",
            description: "Launching the new calendar project!"
          }
        ]
      });
    });
  </script>
</body>
</html>
